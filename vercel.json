{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/ar/",
      "statusCode": 302
    },
    {
      "source": "/en",
      "destination": "/en/",
      "statusCode": 302
    }
  ]
}
